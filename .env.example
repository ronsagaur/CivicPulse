# ─────────────────────────────────────────────────────────────
# CivicPulse Environment Configuration
# ─────────────────────────────────────────────────────────────

# Mandatory for Database operations (automatically set to SQLite locally)
DATABASE_URL="file:./dev.db"

# Optional: Set this to enable live Gemini 2.0 Flash classification
# and live database conversational RAG chatbot responses.
# Get a key at Google AI Studio (https://aistudio.google.com/)
GEMINI_API_KEY=

# Force the mock classifier even if a key is set (handy for offline demos)
CIVICPULSE_FORCE_MOCK_AI=false

# Google Maps API Key for native Google Maps JavaScript SDK rendering
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
